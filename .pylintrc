[MASTER]
pylint-version=3.0.0

[MESSAGES CONTROL]
disable=
    -fixme
    -no-member
    -no-self-use
    -protected-access
    -too-many-arguments
    -too-many-boolean-expressions
    -too-many-branches
    -too-many-locals
    -too-many-public-methods
    -too-many-return-statements
    -too-many-statements
    -too-few-public-methods
    -duplicate-code

[DESIGN]
max-args=10
max-locals=15
max-returns=10
max-branches=20
max-statements=50
max-parents=7
max-attributes=15
max-public-methods=30

[FORMAT]
max-line-length=120
max-module-lines=1000
indent-string='    '

[BASIC]
good-names=i,j,k,ex,Run,_

[IMPORTS]
prefer-relative-imports=True

[CLASSES]
defining-attr-methods=__init__,__new__

[VARIABLES]
init-import=no
dummy-variables-rgx=_+$|dummy

[SIMILARITIES]
min-similarity-lines=4
ignore-comments=yes
ignore-docstrings=yes
ignore-imports=yes
